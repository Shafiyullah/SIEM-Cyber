# Copy this file to .env and fill in real values before running.
# NEVER commit your actual .env to version control.
# .env is already listed in .gitignore.
#
# Generate secure random strings with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# API Security (REQUIRED)
API_KEY=your-secure-random-api-key-here

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_USER=elastic
ES_PASSWORD=your-elastic-password-here
ES_INDEX_NAME=siem_logs
# Set to true in production to enable TLS certificate verification
ES_USE_TLS=false

# Splunk HEC
# Obtain from: Splunk Web → Settings → Data Inputs → HTTP Event Collector
SPLUNK_HEC_URL=http://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=your-splunk-hec-token-here
SPLUNK_PASSWORD=your-splunk-admin-password-here

# LLM Provider
# Options: local (default), ollama, gemini
LLM_PROVIDER=local
# Required only when LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Required only when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral

# Anomaly Detection
ANOMALY_THRESHOLD=-0.5
ANOMALY_CONTAMINATION=0.1
TRAINING_DAYS=7

# Log Sources
# LOG_SOURCES=/var/log/syslog,/var/log/auth.log
# Windows dev default:
# LOG_SOURCES=test_logs.txt

# Limits
MAX_SEARCH_RESULTS=500
# Log lines buffered before a batch is flushed through the pipeline (latency vs throughput)
LOG_BATCH_SIZE=100

